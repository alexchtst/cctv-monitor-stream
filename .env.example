HIKCONNECT_USERNAME=acinatra@gmail.com
HIKCONNECT_PASSWORD=Qwerty45

# Optional. If omitted, the service will use cameras discovered through Hik-Connect
# only for metadata and will require CAMERA_STREAMS_JSON for frame capture.
CAMERA_STREAMS_JSON=[{"id":"cam-001","name":"Gate 1 - Utama","location":"Main Entrance","hikonekChannelId":"HIK-GATE-001","streamUrl":"rtsp://user:pass@camera-host:554/Streaming/Channels/101"}]

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO engine endpoint that accepts multipart field "frame" plus camera metadata.
AI_ENGINE_URL=http://localhost:9000/predict
AI_ENGINE_TIMEOUT_SECONDS=10

FRAME_INTERVAL_SECONDS=1.0
EVENT_MIN_CONFIDENCE=0.65
EVENT_DEDUPE_SECONDS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_TO=
SMTP_TLS=true
