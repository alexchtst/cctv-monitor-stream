HIKCONNECT_USERNAME=
HIKCONNECT_PASSWORD=

# Optional. If omitted, the service will use cameras discovered through Hik-Connect
# only for metadata and will require CAMERA_STREAMS_JSON for frame capture.
CAMERA_STREAMS_JSON=[]

# Optional. Defines one NVR/DVR per region and builds RTSP camera streams internally.
# Keep usernames/passwords here only; /cameras never returns raw RTSP credentials.
# channels accepts either JSON arrays like [1,2,3] or strings like "1-16".
CAMERA_REGIONS_JSON=[{"name":"SPPG TIMOHO","ip":"","username":"","password":"","channels":"1-16","stream":"02"},{"name":"SPPG KOKAP","ip":"","username":"","password":"","channels":"1-8","stream":"02"},{"name":"SPPG UMBULHARJO","ip":"","username":"","password":"","channels":"1-8","stream":"02"},{"name":"SPPG SEDAYU","ip":"","username":"","password":"","channels":"1-8","stream":"02"}]

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI engine endpoint that accepts multipart field "frame" plus camera metadata.
AI_ENGINE_URL=http://localhost:9000/predict
AI_ENGINE_TIMEOUT_SECONDS=10

FRAME_INTERVAL_SECONDS=1.0
RTSP_TIMEOUT_MICROSECONDS=3000000
EVENT_MIN_CONFIDENCE=0.65
EVENT_DEDUPE_SECONDS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_TO=
SMTP_TLS=true
